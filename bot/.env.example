# Скопируй этот файл в .env и заполни значения

# Токен от @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Твой Telegram user_id — куда бот будет слать уведомления с сайта
# Узнать можно у @userinfobot — напиши ему /start
ADMIN_CHAT_ID=123456789

# Порт для FastAPI (оставь 8000 если не знаешь)
PORT=8000
